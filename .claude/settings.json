{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(basename *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(pdflatex *)",
      "Bash(pdfinfo *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(rm *)",
      "Read(./**)",
      "Write(output/**)",
      "Write(parsed/**)",
      "Edit(output/**)",
      "Edit(parsed/**)"
    ],
    "deny": [
      "Write(templates/**)",
      "Edit(templates/**)",
      "Write(context/**)",
      "Edit(context/**)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "WebFetch",
      "WebSearch"
    ]
  }
}